  if (!fs.existsSync(jsonPath)) {
    console.error('Physics JSON not found at', jsonPath);
    return;
  }
  const questions: any[] = JSON.parse(fs.readFileSync(jsonPath, 'utf-8'));
  const numQuizzes = Math.ceil(questions.length / QUIZ_SIZE);

